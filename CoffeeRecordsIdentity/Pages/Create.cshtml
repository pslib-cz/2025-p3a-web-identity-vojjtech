@page
@using CoffeeRecordsIdentity.Areas.Identity.Data
@using Microsoft.AspNetCore.Identity
@model CoffeeRecordsIdentity.Pages.CreateModel
@{
    ViewData["Title"] = "Create";
}

@inject SignInManager<CoffeeRecordsIdentityUser> SignInManager
@inject UserManager<CoffeeRecordsIdentityUser> UserManager

<h1>Create</h1>

<h4>CoffeeCup</h4>
<hr />
@if (SignInManager.IsSignedIn(User))
{
    <div class="row">
        <div class="col-md-4">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-group">
                    <label asp-for="Input.UserName" class="control-label"></label>
                    <input asp-for="Input.UserName" class="form-control" />
                    <span asp-validation-for="Input.UserName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Input.MachineNo" class="control-label"></label>
                    <input asp-for="Input.MachineNo" class="form-control" />
                    <span asp-validation-for="Input.MachineNo" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <input type="submit" value="Create" class="btn btn-primary" />
                </div>
            </form>
        </div>
    </div>

}
else
{
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Register">Register</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Login</a>
        </li>
    </ul>
}

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
